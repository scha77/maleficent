rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Evidence collection — anyone can read, add, and delete
    match /evidence/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['type', 'category', 'createdAt'])
                    && request.resource.data.type in ['embed', 'image', 'username']
                    && request.resource.data.category in [
                         'lies', 'manipulation', 'money',
                         'character', 'relationships', 'other'
                       ]
                    && request.resource.data.size() <= 15;
      allow delete: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['categories', 'category', 'caption', 'sourceDate']);
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
